{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-6-latest",
      "enable_thinking": true,
      "effort": "high",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "context_servers": {
    "claude-code": {
      "command": "claude",
      "args": ["mcp", "serve"],
    },
  },
  "buffer_font_family": "Monaspace Xenon",
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
      "default_model": "opus",
      "favorite_models": ["opus"],
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "tab_size": 2,
  "tab_bar": {
    "show": true,
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "soft_wrap": "editor_width",
  "theme": {
    "mode": "dark",
    "light": "Zed Legacy: Atelier Cave Light",
    "dark": "Atom Dark",
  },
}
