#!/usr/bin/env bash

# setup-nightly-clean вЂ” One-time setup for the nightly-clean job
# Run this interactively to install everything. Afterward it's hands-off.
#
# What this does:
#   1. Symlinks the script to /usr/local/bin/nightly-clean
#   2. Installs the launchd plist into ~/Library/LaunchDaemons
#   3. Configures pmset to wake the machine at 23:58 every Friday
#   4. Prints the sudoers line you need to add manually
#
# Author: Jonathan Simcoe

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT_SRC="${SCRIPT_DIR}/nightly-clean"
PLIST_SRC="${SCRIPT_DIR}/com.jdsimcoe.nightly-clean.plist"
INSTALL_PATH="/usr/local/bin/nightly-clean"
PLIST_DEST="/Library/LaunchDaemons/com.jdsimcoe.nightly-clean.plist"

GREEN="\033[0;32m"; YELLOW="\033[1;33m"; RED="\033[0;31m"; NC="\033[0m"

echo -e "${YELLOW}в–¶ Setting up nightly-clean...${NC}"
echo ""

# в”Ђв”Ђ 1. Symlink the script в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${YELLOW}1) Installing script to ${INSTALL_PATH}${NC}"
sudo ln -sf "${SCRIPT_SRC}" "${INSTALL_PATH}"
sudo chmod +x "${INSTALL_PATH}"
echo -e "${GREEN}вњ” Script installed.${NC}"
echo ""

# в”Ђв”Ђ 2. Install the launchd plist в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Using /Library/LaunchDaemons (system-level) so it runs as root
# and can execute sudo commands without the user being logged in
echo -e "${YELLOW}2) Installing launchd plist to ${PLIST_DEST}${NC}"
sudo cp "${PLIST_SRC}" "${PLIST_DEST}"
sudo chown root:wheel "${PLIST_DEST}"
sudo chmod 644 "${PLIST_DEST}"

# Update the plist to run as root (since it's a LaunchDaemon now)
# We need to add a UserName key so the user-level caches are found
sudo /usr/libexec/PlistBuddy -c "Delete :UserName" "${PLIST_DEST}" 2>/dev/null || true
sudo /usr/libexec/PlistBuddy -c "Add :UserName string jdsimcoe" "${PLIST_DEST}"

sudo launchctl bootout "system/com.jdsimcoe.nightly-clean" 2>/dev/null || true
sudo launchctl bootout system "${PLIST_DEST}" 2>/dev/null || true
sudo launchctl bootstrap system "${PLIST_DEST}"
echo -e "${GREEN}вњ” LaunchDaemon installed and loaded.${NC}"
echo ""

# в”Ђв”Ђ 3. Schedule wake-from-sleep в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${YELLOW}3) Scheduling weekly wake for Friday 23:58${NC}"
# Cancel any existing repeating wake schedule first
sudo pmset repeat cancel 2>/dev/null || true
sudo pmset repeat wakeorpoweron F 23:58:00
echo -e "${GREEN}вњ” pmset wake schedule set. Machine will wake on Friday at 23:58.${NC}"
echo ""

# в”Ђв”Ђ 4. Sudoers reminder в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${YELLOW}4) Sudoers configuration${NC}"
echo ""
echo "  Since the plist runs as a LaunchDaemon (root), the script's"
echo "  sudo calls will already have root privileges вЂ” no sudoers"
echo "  change is needed for the automated run."
echo ""
echo "  If you ever want to run the script manually as your user,"
echo "  add this line to /etc/sudoers.d/nightly-clean:"
echo ""
echo -e "  ${GREEN}jdsimcoe ALL=(ALL) NOPASSWD: ${INSTALL_PATH}${NC}"
echo ""
echo "  To do that safely:"
echo ""
echo "    sudo visudo -f /etc/sudoers.d/nightly-clean"
echo ""
echo "  Then paste:"
echo "    jdsimcoe ALL=(ALL) NOPASSWD: /usr/local/bin/nightly-clean"
echo ""

# в”Ђв”Ђ 5. Verify в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${YELLOW}5) Verification${NC}"
echo ""
echo "  Script:    $(ls -la ${INSTALL_PATH})"
echo "  Plist:     $(ls -la ${PLIST_DEST})"
echo "  pmset:     $(pmset -g sched 2>/dev/null | head -5 || echo '(check manually)')"
echo "  launchctl: $(sudo launchctl list | grep nightly-clean || echo '(not yet visible вЂ” will appear at next interval)')"
echo ""
echo -e "${GREEN}вњ” Setup complete. Your Mac will wake on Friday at 23:58 and run nightly-clean at 00:00 on Saturday.${NC}"
echo ""
echo "  To test manually:  sudo /usr/local/bin/nightly-clean"
echo "  To view logs:      cat /tmp/nightly-clean-\$(date +%Y%m%d).log"
echo "  To uninstall:      sudo launchctl bootout system /com.jdsimcoe.nightly-clean"
echo "                     sudo rm ${PLIST_DEST} ${INSTALL_PATH}"
echo "                     sudo pmset repeat cancel"
